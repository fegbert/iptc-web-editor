generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model WorkspaceFile {
  id            String    @id @default(cuid())
  clerkOrgId    String
  name          String
  path          String    @default("/")
  r2Key         String    @unique
  size          Int
  metadata      Json      @default("{}")
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
